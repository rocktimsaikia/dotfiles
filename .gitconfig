[user]
	name = rocktimsaikia
	email = rocktimthedev@gmail.com
[color]
	ui = true
[core]
	editor = nvim
[init]
	defaultBranch = main

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
