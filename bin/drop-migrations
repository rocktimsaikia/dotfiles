#!/bin/bash

# Delete newly created migration files in the current branch
# Finds untracked and staged-as-added files under any "migrations" folder/subfolder

# Ensure we're in a git repo
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Error: Not inside a git repository."
  exit 1
fi

# Find newly added (staged) and untracked files under any migrations folder
migration_files=$(git status --porcelain | awk '
  /^A  .*migrations/ || /^\?\? .*migrations/ { print $2 }
' | grep -E '(^|/)migrations/')

if [ -z "$migration_files" ]; then
  echo "No new migration files found."
  exit 0
fi

echo "New migration files to delete:"
echo "$migration_files" | while IFS= read -r f; do
  echo "  $f"
done
echo ""

# Confirm before deleting
echo -n "Delete these files? [y/N] "
read -r confirm

if [[ "$confirm" =~ ^[Yy]$ ]]; then
  echo "$migration_files" | while IFS= read -r f; do
    if [ -f "$f" ]; then
      rm "$f"
      echo "Deleted: $f"
    else
      echo "Skipped (not found): $f"
    fi
  done
  echo ""
  echo "Done."
else
  echo "Aborted."
fi
