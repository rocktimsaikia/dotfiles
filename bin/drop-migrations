#!/bin/bash

# Delete migration files added on the current branch.
# Prefer files added relative to the repository's default integration branch, and
# fall back to staged-as-added or untracked local migration files when no branch
# diff is available.

# Ensure we're in a git repo
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Error: Not inside a git repository."
  exit 1
fi

get_base_ref() {
  local current_branch upstream upstream_branch
  current_branch=$(git branch --show-current 2>/dev/null)
  upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null)
  upstream_branch=${upstream#origin/}

  if [ -n "$upstream" ] && [ "$upstream_branch" != "$current_branch" ]; then
    echo "$upstream"
    return 0
  fi

  if git show-ref --verify --quiet refs/remotes/origin/master; then
    echo "origin/master"
    return 0
  fi

  if git show-ref --verify --quiet refs/remotes/origin/main; then
    echo "origin/main"
    return 0
  fi

  if [ -n "$upstream" ]; then
    echo "$upstream"
    return 0
  fi

  return 1
}

get_branch_added_migrations() {
  local base_ref="$1"
  git diff --name-status "$base_ref"...HEAD 2>/dev/null | awk '
    $1 == "A" && $2 ~ /(^|\/)migrations\// { print $2 }
  '
}

get_local_added_migrations() {
  git status --porcelain | awk '
    /^A  / || /^\?\?/ {
      path = substr($0, 4)
      if (path ~ /(^|\/)migrations\//) {
        print path
      }
    }
  '
}

base_ref=$(get_base_ref)
migration_files=""

if [ -n "$base_ref" ]; then
  migration_files=$(get_branch_added_migrations "$base_ref")
fi

if [ -z "$migration_files" ]; then
  migration_files=$(get_local_added_migrations)
fi

migration_files=$(printf '%s\n' "$migration_files" | sed '/^$/d' | sort -u)

if [ -z "$migration_files" ]; then
  echo "No new migration files found."
  exit 0
fi

echo "New migration files to delete:"
echo "$migration_files" | while IFS= read -r f; do
  echo "  $f"
done
echo ""

# Confirm before deleting
echo -n "Delete these files? [y/N] "
read -r confirm

if [[ "$confirm" =~ ^[Yy]$ ]]; then
  echo "$migration_files" | while IFS= read -r f; do
    if [ -f "$f" ]; then
      rm "$f"
      echo "Deleted: $f"
    else
      echo "Skipped (not found): $f"
    fi
  done
  echo ""
  echo "Done."
else
  echo "Aborted."
fi
