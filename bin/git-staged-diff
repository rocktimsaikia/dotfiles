#!/usr/bin/env bash

# Interactively pick a staged file and show its diff.

set -euo pipefail

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "Error: not a git repository" >&2
  exit 1
fi

files=$(git diff --staged --name-only)

if [ -z "$files" ]; then
  echo "No staged files."
  exit 0
fi

selected=$(printf '%s\n' "$files" | fzf \
  --prompt="Staged file > " \
  --height=40% \
  --reverse \
  --preview="git diff --staged --color=always -- {}" \
  --preview-window=right:70%:wrap)

if [ -z "${selected:-}" ]; then
  exit 0
fi

clear
git diff --staged -- "$selected"
