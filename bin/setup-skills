#!/usr/bin/env bash
# Sync ~/dotfiles/skills into Codex, Claude, and Copilot CLI skill directories.
set -euo pipefail

src="${SKILLS_SOURCE:-$HOME/dotfiles/skills}"
codex_dir="${CODEX_SKILLS_TARGET:-$HOME/.codex/skills}"
claude_dir="${CLAUDE_COMMANDS_TARGET:-$HOME/.claude/commands}"
copilot_dir="${COPILOT_SKILLS_TARGET:-$HOME/.copilot/skills}"

mkdir -p "$codex_dir" "$claude_dir" "$copilot_dir"

if [[ ! -d "$src" ]]; then
    echo "missing source directory: $src" >&2
    exit 1
fi

prune_stale_links() {
    local target_dir="$1"
    local expected_prefix="$2"
    local item

    shopt -s nullglob
    for item in "$target_dir"/*; do
        [[ -L "$item" ]] || continue
        if [[ "$(readlink "$item")" == "$expected_prefix"* && ! -e "$item" ]]; then
            rm "$item"
            echo "removed stale link: $item"
        fi
    done
    shopt -u nullglob
}

prune_stale_links "$codex_dir" "$src/"
prune_stale_links "$claude_dir" "$src/"
prune_stale_links "$copilot_dir" "$src/"

shopt -s nullglob
for d in "$src"/*/; do
    name=$(basename "$d")
    skill_file="$src/$name/SKILL.md"

    [[ -f "$skill_file" ]] || continue

    ln -sfn "$src/$name" "$codex_dir/$name"
    ln -sfn "$skill_file" "$claude_dir/$name.md"
    ln -sfn "$src/$name" "$copilot_dir/$name"
    echo "synced: $name"
done
shopt -u nullglob
